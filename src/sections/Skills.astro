---
import SkillCard from "../components/SkillCard.astro";
import { getCollection } from "astro:content";

const allSkills = await getCollection("skills");
---

<section class="grid col-span-1 gap-6 md:gap-10">
  <h2 class="text-5xl font-extrabold pb-4 md:text-8xl">TECH SKILLS</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    {
      allSkills.map((i) => (
        <SkillCard skill={i.data.skill} text={i.data.text} img={i.data.img} />
      ))
    }
  </div>
</section>
