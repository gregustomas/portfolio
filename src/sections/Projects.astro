---
import { getCollection } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";

const allProjects = await getCollection("projects");
---

<section class="section-layout reveal">
  <h2 class="section-heading">RECENT PROJECTS</h2>

  <div class="grid grid-cols-1 gap-5">
    {
      allProjects.map((i) => (
        <ProjectCard
          url={i.data.url}
          img={i.data.img}
          clr={i.data.clr}
          project={i.data.project}
          text={i.data.text}
          stack={i.data.stack}
        />
      ))
    }
  </div>

  <p class="text-xl font-semibold text-center pt-4">More in development...</p>
</section>
