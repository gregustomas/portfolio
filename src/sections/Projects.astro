---
import { getCollection } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";

const allProjects = await getCollection("projects");
---

<section>
  <h2 class="text-5xl font-extrabold pb-4 md:text-8xl md:pb-6">
    RECENT PROJECTS
  </h2>

  {allProjects.map(i => (
    <ProjectCard
    url={i.data.url}
    img={i.data.img}
    clr={i.data.clr}
    project={i.data.project}
    text={i.data.text}
  />

  ))}

  <p class="text-xl font-semibold text-center pt-4">A další ve vývoji...</p>
</section>
