---
import { Image } from "astro:assets";

interface Props {
  title: string;
  text: string;
  img: ImageMetadata;
  date: string;
}

const { title, text, img, date } = Astro.props;
---

<div
  class="rounded-2xl bg-dark text-slate-100 py-6 px-8 md:flex gap-2 md:px-10"
>
  <div>
    <h3 class="pb-2 font-bold text-lg md:text-2xl">Highlight: {title}</h3>
    <p class="text-gray-400 pb-6">
      {text}
    </p>
  </div>

  <Image src={img} alt={title} class="w-20 m-auto" />
</div>
