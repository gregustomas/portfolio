---
import { Image } from "astro:assets";

interface Props {
  title: string;
  text: string;
  img: ImageMetadata;
  date: string;
}

const { title, text, img, date } = Astro.props;
---

<div class="project-card group relative rounded-3xl bg-[#1a1a1a] border border-white/5 p-8 md:p-10 flex flex-col md:flex-row gap-8 items-center overflow-hidden transition-all duration-500 hover:border-primary/50 hover:shadow-[0_0_30px_rgba(16,167,205,0.1)]">
  
  <div class="flex-1 z-10">
    <div class="flex items-center gap-3 mb-4">
      <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest border border-primary/20">
        Highlight
      </span>
      <span class="text-slate-500 text-xs font-mono">{date}</span>
    </div>
    
    <h3 class="text-3xl md:text-4xl font-black text-white mb-4 leading-tight uppercase">
      {title}
    </h3>
    
    <p class="text-slate-400 text-base md:text-lg leading-relaxed max-w-xl">
      {text}
    </p>
  </div>

  <div class="relative w-32 h-32 md:w-48 md:h-48 flex-shrink-0 flex items-center justify-center bg-white/5 rounded-2xl p-6 group-hover:bg-white/10 transition-colors duration-500">
    <Image 
      src={img} 
      alt={title} 
      class="w-full h-full object-contain filter drop-shadow-2xl group-hover:scale-110 transition-transform duration-700" 
    />
    
    <div class="absolute inset-0 bg-primary/20 blur-[50px] opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
  </div>
</div>