---
import { Image } from 'astro:assets';
import profileImg from "../assets/profile.jpg";
---

<div
  class="w-full flex flex-col gap-8 bg-linear-to-b from-primary to-light rounded-2xl px-8 py-12 shadow-md md:max-w-md"
>
  <Image
    src={profileImg}
    alt="Tomáš Greguě"
    class="w-full h-85 object-cover object-top rounded-2xl"
  />

  <div>
    <div class="text-center mb-6">
      <h2 class="section-heading mb-2 text-4xl md:text-5xl">Tomáš Greguš</h2>
      <p>Frontend dev, se zálibou v tvorbě webů a aplikací pomocí Reactu.</p>
    </div>
    <div class="flex justify-center gap-12 md:gap-10 text-4xl md:text-3xl">
      <a href="https://github.com/gregustomas">
        <i class="fi fi-brands-github"></i>
      </a>
      <a href="https://www.linkedin.com/in/tomas-gregus/">
        <i class="fi fi-brands-linkedin"></i>
      </a>
      <a href="https://www.instagram.com/tomasgregus1/">
        <i class="fi fi-brands-instagram"></i>
      </a>
    </div>
  </div>
</div>
