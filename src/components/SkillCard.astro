---
import { Image } from "astro:assets";

interface Props {
  img: ImageMetadata;
  skill: string;
  text: string;
}

const { img, skill, text } = Astro.props;
---

<div class="cursor-pointer flex gap-4 items-center w-full group">
  <div class="w-20 h-20 shrink-0 bg-slate-50 rounded-2xl flex items-center justify-center p-4 overflow-hidden shadow-sm">
    <Image 
      src={img} 
      alt={skill} 
      class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-300"
    />
  </div>

  <div class="min-w-0"> <h3 class="text-xl font-black uppercase tracking-tight leading-none mb-1 truncate">{skill}</h3>
    <p class="text-sm text-slate-500 leading-snug line-clamp-2">{text}</p>
  </div>
</div>
