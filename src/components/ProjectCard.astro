---
import { Image } from "astro:assets";
import { ExternalLink } from "lucide-react";

interface Props {
  url: string;
  img: ImageMetadata;
  project: string;
  text: string;
  clr: string;
  stack: string[];
}

const { url, img, clr, project, text, stack } = Astro.props;
---

<a
  href={url}
  class="flex items-start justify-between gap-4 p-4 rounded-4xl hover:bg-slate-50 transition-colors group"
>
  <div class="flex gap-6 items-center min-w-0 flex-1">
    <div
      class:list={[
        "w-24 h-24 rounded-2xl relative overflow-hidden shrink-0",
        clr,
      ]}
    >
      <Image
        src={img}
        alt={project}
        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[80%] h-auto object-cover rounded-t-lg shadow-sm group-hover:scale-110 transition-transform duration-300"
      />
    </div>

    <div class="min-w-0">
      <h3 class="card-title">{project}</h3>
      <p class="leading-tight text-sm pb-4">{text}</p>
      <div class="flex flex-wrap gap-2">
        {
          stack.map((s) => (
            <span class="px-2 py-0.5 text-xs text-dark/80 rounded-full bg-muted">
              {s}
            </span>
          ))
        }
      </div>
    </div>
  </div>

  <div class="pt-2 pl-3 shrink-0 text-slate-400 group-hover:text-slate-900 transition-colors">
    <ExternalLink size={18} />
  </div>
</a>
